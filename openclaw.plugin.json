{
  "id": "rides",
  "name": "Rides",
  "description": "Track Singapore ride-hailing expenses by syncing Gmail receipts and parsing screenshots. Supports Grab, Gojek, and more with budget tracking and currency conversion.",
  "skills": ["./skills"],
  "contracts": {
    "tools": [
      "log_ride",
      "list_rides",
      "search_rides",
      "update_ride",
      "delete_ride",
      "ride_spending_stats",
      "set_ride_budget",
      "get_budget_status",
      "sync_ride_emails",
      "parse_receipt_screenshot"
    ]
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "googleClientId": {
        "type": "string",
        "description": "Google OAuth2 Client ID for Gmail API access"
      },
      "googleClientSecret": {
        "type": "string",
        "description": "Google OAuth2 Client Secret"
      },
      "googleAiApiKey": {
        "type": "string",
        "description": "Google AI API key for Gemini 2.0 Flash. Optional — enables screenshot parsing."
      },
      "baseUrl": {
        "type": "string",
        "description": "Public URL of the OpenClaw instance (for OAuth redirect URI)"
      },
      "defaultCurrency": {
        "type": "string",
        "default": "SGD",
        "enum": ["SGD", "USD", "MYR"]
      },
      "defaultCategory": {
        "type": "string",
        "default": "personal",
        "enum": ["work", "personal"]
      },
      "syncIntervalMinutes": {
        "type": "number",
        "default": 15
      }
    },
    "required": []
  }
}
